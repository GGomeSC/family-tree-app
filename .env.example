# Copy this file to .env for local development with Docker Compose.
# Never commit real secrets.
APP_NAME=Family Tree API
ENVIRONMENT=development
SECRET_KEY=replace-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=720
PYTHONPATH=/app
DATABASE_URL=postgresql+psycopg2://family_tree:family_tree@db:5432/family_tree
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1|10\.\d+\.\d+\.\d+|172\.(1[6-9]|2\d|3[0-1])\.\d+\.\d+|192\.168\.\d+\.\d+):5173
EXPORT_DIR=/app/exports
VITE_API_URL=http://localhost:8000/api/v1
