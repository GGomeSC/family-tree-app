APP_NAME=Family Tree API
ENVIRONMENT=development
#
# For staging/production, SECRET_KEY is required and must be at least 32 characters.
# Generate one with: openssl rand -hex 32
SECRET_KEY=replace-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=720
# Backend-local PostgreSQL example. Alembic migrations require DATABASE_URL to be set explicitly.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/family_tree
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGIN_REGEX=http://(localhost|127\.0\.0\.1|10\.\d+\.\d+\.\d+|172\.(1[6-9]|2\d|3[0-1])\.\d+\.\d+|192\.168\.\d+\.\d+):5173
EXPORT_DIR=./exports
AUTH_COOKIE_NAME=access_token
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=strict
AUTH_COOKIE_PATH=/
LOGIN_RATE_LIMIT_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
#
# Optional local bootstrap admin values.
# BOOTSTRAP_ADMIN_EMAIL=admin.local@example.com
# BOOTSTRAP_ADMIN_PASSWORD=change-this-password
# BOOTSTRAP_ADMIN_NAME=Local Admin
